{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",           // ◄ Changé ici
    "moduleResolution": "NodeNext", // ◄ Changé ici
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}